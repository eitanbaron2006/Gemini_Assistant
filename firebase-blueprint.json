{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was first created" }
      },
      "required": ["uid", "email"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A single voice conversation session",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this conversation" },
        "title": { "type": "string", "description": "A short summary or title of the conversation" },
        "transcript": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "isUser": { "type": "boolean" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "language": { "type": "string", "enum": ["he", "en"] }
      },
      "required": ["userId", "transcript", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Stored conversation histories"
    }
  }
}
